{
  "name": "tayo-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "admin",
    "client",
    "components",
    "database",
    "email"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:admin": "bun run --filter admin dev",
    "dev:client": "bun run --filter client dev",
    "build": "bun run --filter '*' build",
    "build:admin": "bun run --filter admin build",
    "build:client": "bun run --filter client build",
    "start": "bun run --filter '*' start",
    "start:admin": "bun run --filter admin start",
    "start:client": "bun run --filter client start",
    "lint": "bun run --filter '*' lint",
    "db:generate": "bun run --filter @tayo/database db:generate",
    "db:migrate": "bun run --filter @tayo/database db:migrate",
    "db:push": "bun run --filter @tayo/database db:push",
    "db:studio": "bun run --filter @tayo/database db:studio",
    "db:seed": "bun run --filter @tayo/database db:seed",
    "clean": "rm -rf node_modules admin/node_modules client/node_modules components/node_modules database/node_modules"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "3.0.0",
    "@next/eslint-plugin-next": "^16.2.5",
    "@setemiojo/eslint-config": "^8.2.2",
    "@setemiojo/utils": "^0.0.6",
    "admin": "workspace:*",
    "bun-types": "latest"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "better-all": "^0.0.7",
    "clsx": "^2.1.1"
  }
}
